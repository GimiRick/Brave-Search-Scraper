{
  "name": "gimirick-brave-search-scraper",
  "version": "1.0.5",
  "description": "Server-side scraper that queries Brave Search and extracts URLs",
  "license": "CC-BY-NC-ND-4.0",
  "engines": {
    "node": ">=20.18.1"
  },
  "main": "src/scraper.js",
  "bin": {
    "brave-search-scraper": "src/scraper.js"
  },
  "scripts": {
    "start": "node src/scraper.js",
    "start:dev": "node --watch src/scraper.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "pretest": "node --check src/scraper.js && node --check src/logger.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0"
  }
}
